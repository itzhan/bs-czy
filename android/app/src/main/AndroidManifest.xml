<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />

    <application
        android:name=".ZhihuApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.CampusZhihu"
        android:usesCleartextTraffic="true">

        <activity
            android:name=".ui.auth.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.CampusZhihu.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".ui.auth.AuthActivity" android:exported="false" />
        <activity android:name=".ui.home.MainActivity" android:exported="false" />
        <activity android:name=".ui.question.QuestionDetailActivity" android:exported="false" />
        <activity android:name=".ui.question.AskQuestionActivity" android:exported="false" />
        <activity android:name=".ui.profile.UserDetailActivity" android:exported="false" />
        <activity android:name=".ui.profile.UserListActivity" android:exported="false" />
    </application>
</manifest>
